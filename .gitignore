/distribution/android/whatsnew/

# Generated Apple Store release notes (Fastlane metadata)
/distribution/apple/fastlane/metadata/

# Generated Windows release notes metadata
/distribution/windows/current_metadata.json
/distribution/windows/update_metadata.json

# Linux Snap packages
*.snap
